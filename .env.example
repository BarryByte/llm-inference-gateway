DATABASE_URL=postgresql+asyncpg://gateway:gateway@postgres:5432/gateway
REDIS_URL=redis://redis:6379

PROVIDER_RATE_LIMIT=300
RATE_LIMIT_WINDOW_SECONDS=60

MAX_QUEUE_DEPTH=10000
VISIBILITY_TIMEOUT_SECONDS=30
MAX_RETRIES=3
STARVATION_MAX_WAIT_SECONDS=60

SIMILARITY_THRESHOLD=0.92
EMBEDDING_MODEL=all-MiniLM-L6-v2
CACHE_TTL_SECONDS=86400

OLLAMA_URL=http://ollama:11434
CLASSIFIER_MODEL=qwen2.5:0.5b

WORKER_COUNT=4
WAL_PATH=/tmp/gateway-wal

# Provider: "mock" (default) or "claude"
PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
